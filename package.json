{
	"name": "awesome-vitest",
	"version": "0.0.0",
	"private": true,
	"license": "CC0-1.0",
	"author": {
		"name": "Dom Porada",
		"email": "dom@dom.engineering",
		"url": "https://dom.engineering"
	},
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.14.0",
	"devDependencies": {
		"@standard-config/prettier": "^1.16.0",
		"prettier": "^3.9.6",
		"simple-git-hooks": "^2.13.1"
	},
	"scripts": {
		"fix": "pnpm format",
		"format": "prettier --ignore-unknown --log-level=warn --write .",
		"format:check": "prettier --check --ignore-unknown .",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm format:check"
	}
}
